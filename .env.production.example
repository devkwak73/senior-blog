# ============================================
# .env.production - 운영 환경 (Linux VPS)
# DATABASE_SOCKET 없으면 자동으로 TCP 연결 사용
# ============================================

# ── MySQL (TCP 연결) ──
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=senior_blog
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_NAME=senior_blog
# DATABASE_SOCKET 미설정 → TCP 연결 사용

# ── 사이트 ──
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME=토닥토닥 시니어

# ── hCaptcha ──
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=CHANGE_ME
HCAPTCHA_SECRET_KEY=CHANGE_ME

# ── 관리자 API 인증 ──
ADMIN_API_KEY=CHANGE_ME_STRONG_RANDOM_KEY

# ── Rate Limit ──
COMMENT_RATE_LIMIT=3
RATE_LIMIT_WINDOW=60
